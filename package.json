{
  "name": "license-webpack-plugin",
  "version": "1.0.0",
  "description": "A webpack 5 plugin to generate third-party license notices for bundled packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:rspack": "jest --testPathPattern=tests/integration/rspack.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "webpack",
    "license",
    "plugin",
    "third-party",
    "compliance"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "devDependencies": {
    "@rspack/core": "^1.7.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "jest": "^29.7.0",
    "lodash": "^4.17.21",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.4",
    "webpack": "^5.93.0",
    "webpack-sources": "^3.2.3"
  }
}
